# ── FashionHub Environment Variables ──────────────────────
# Copy this to .env for local development. NEVER commit .env to git.

# Server
PORT=8080
NODE_ENV=development
ALLOWED_ORIGIN=http://localhost:8080

# Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=fashionuser
DB_PASSWORD=your_secure_password_here
DB_NAME=fashiondb

# Auth
JWT_SECRET=replace_with_a_long_random_secret_min_32_chars
